# ============================================================
# Nordic Digital Solutions - Environment Example
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to GitHub.
# ============================================================

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/nordic_digital_solutions

# JWT Authentication
SECRET_KEY=replace-with-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# BankID - set BANKID_MOCK_MODE=false for real BankID
BANKID_MOCK_MODE=true
BANKID_BASE_URL=https://appapi2.test.bankid.com
BANKID_CERT_FILE=certs/FPTestcert5_20240610.pem
BANKID_CERT_PASSWORD=qwerty123
BANKID_CA_FILE=certs/bankid_test_ca.pem
BANKID_END_USER_IP=127.0.0.1

# Stripe - leave empty to use invoice mock
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYMENT_PROVIDER=stripe

# Google Cloud Translate - leave empty for mock
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLIENT_SECRET_FILE=

# Anthropic AI - required for real AI chat
ANTHROPIC_API_KEY=

# Notification - leave empty for mock mode
HELLOSMS_API_URL=https://api.hellosms.se/v1/
HELLOSMS_USERNAME=
HELLOSMS_PASSWORD=
SMTP2GO_API_URL=https://api.smtp2go.com/v3/
SMTP2GO_API_KEY=
SMTP2GO_SENDER=noreply@nordicdigitalsolutions.se
NOTIFICATION_ADMIN_TOKEN=changeme
NOTIFICATION_PG_HOST=localhost
NOTIFICATION_PG_PORT=5432
NOTIFICATION_PG_DATABASE=nordic_digital_solutions
NOTIFICATION_PG_USER=
NOTIFICATION_PG_PASSWORD=
NOTIFICATION_COOLDOWN_SMS_HOURS=720
NOTIFICATION_COOLDOWN_EMAIL_HOURS=168
SITE_PAGE_BASE_URL=http://localhost:8000/widget

# CORS - set to specific origins in production
CORS_ORIGINS=*
