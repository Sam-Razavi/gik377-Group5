# ============================================================
# Nordic Digital Solutions - Environment Example
# ============================================================
# How to use:
# 1. Copy this file and rename the copy to .env
# 2. Fill in your real local/shared values in .env
# 3. Do NOT commit your real .env file to GitHub
#
# .env.example = safe template, can be pushed
# .env         = private local secrets, should stay in .gitignore
# ============================================================


# ============================================================
# Database - Main backend database
# ============================================================
# Used by the main backend/auth module.
# Example format:
# postgresql://username:password@host:port/database_name

DATABASE_URL=postgresql://username:password@localhost:5432/nordic_digital_solutions


# ============================================================
# Authentication / JWT
# ============================================================
# SECRET_KEY is used to sign JWT tokens.
# Use a long random string in your real .env.

SECRET_KEY=replace-with-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60


# ============================================================
# BankID test environment
# ============================================================
# Used by Sam's authentication module.
# Certificate files should exist locally in the certs/ folder.

# Stripe (kortbetalning) — använd sk_test_... från Stripe Dashboard
STRIPE_SECRET_KEY=sk_test_...
PAYMENT_PROVIDER=stripe

# Google Cloud Translate — peka på din service account-nyckel
GOOGLE_APPLICATION_CREDENTIALS=path/to/key.json
# BankID (test environment)
BANKID_BASE_URL=https://appapi2.test.bankid.com
BANKID_CERT_FILE=certs/your-bankid-test-certificate.pem
BANKID_CERT_PASSWORD=replace-with-bankid-certificate-password
BANKID_CA_FILE=certs/bankid_test_ca.pem
BANKID_END_USER_IP=127.0.0.1

# Anthropic (UNESCO AI-chatt)
ANTHROPIC_API_KEY=sk-ant-...
# Notification – HelloSMS
HELLOSMS_API_URL=https://api.hellosms.se/v1/
HELLOSMS_USERNAME=hellosms_user
HELLOSMS_PASSWORD=hellosms_password

# Notification – SMTP2GO
SMTP2GO_API_URL=https://api.smtp2go.com/v3/
SMTP2GO_API_KEY=api-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SMTP2GO_SENDER=nordicdigitalsolutions@hotmail.com

# Notification – admin & DB
NOTIFICATION_ADMIN_TOKEN=admintoken123
NOTIFICATION_PG_USER=postgres
NOTIFICATION_PG_PASSWORD=postgres

# Notification – bas-URL till världsarvssidan (länken som skickas i SMS/mejl)
SITE_PAGE_BASE_URL=https://nordicdigitalsolutions.se/site.html

# ============================================================
# Notification service - SMS / Email
# ============================================================
# Used by Riyaaq's notification module.
# Use real values only in your local .env.
# These example values are placeholders.

HELLOSMS_USERNAME=replace-with-hellosms-username
HELLOSMS_PASSWORD=replace-with-hellosms-password
SMTP2GO_API_KEY=replace-with-smtp2go-api-key
ADMIN_TOKEN=replace-with-admin-token


# ============================================================
# Notification service - PostgreSQL database
# ============================================================
# Used by the notification module if it has its own DB settings.
# If the group uses the same database as DATABASE_URL, copy the
# same database connection details here.

NOTIFICATION_PG_USER=username
NOTIFICATION_PG_PASSWORD=password
NOTIFICATION_PG_HOST=localhost
NOTIFICATION_PG_PORT=5432
NOTIFICATION_PG_DATABASE=nordic_digital_solutions


# ============================================================
# Payment service
# ============================================================
# Used by Nina's payment module.
# For local development, PAYMENT_PROVIDER=mock is recommended.
#
# If Stripe is used, STRIPE_SECRET_KEY should be a test key
# that starts with sk_test_.

PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=replace-with-stripe-test-secret-key


# ============================================================
# Translation service
# ============================================================
# Used by Nina's translation module.
# For local development, mock fallback can be used if Google
# credentials or packages are missing.
#
# If Google Translate is used, GOOGLE_APPLICATION_CREDENTIALS
# should point to a local JSON credentials file.

TRANSLATION_PROVIDER=mock
GOOGLE_APPLICATION_CREDENTIALS=path/to/google-credentials.json


# ============================================================
# LibreTranslate fallback / alternative
# ============================================================
# Only needed if the translation provider uses LibreTranslate.

LIBRETRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_API_KEY=replace-with-libretranslate-api-key-if-needed


# ============================================================
# Frontend / CORS
# ============================================================
# Optional for later if we change CORS from "*" to specific URLs.
# Current app.py may still allow all origins during development.

CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://127.0.0.1:3000


# ============================================================
# Development notes
# ============================================================
# Recommended local defaults:
#
# PAYMENT_PROVIDER=mock
# TRANSLATION_PROVIDER=mock
#
# This makes it easier to start the full backend without real
# Stripe or Google credentials.
# ============================================================
